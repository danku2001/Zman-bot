# Local web can point to the local Express API. Leave empty on Vercel for same-origin API routes.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Vercel server-side env vars
APP_URL=https://YOUR_VERCEL_DOMAIN
DATABASE_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
API_SECRET=
CRON_SECRET=
DASHBOARD_PASSWORD=
TZ=Asia/Jerusalem
